# ============================================================
# ShowingDay — Environment Variables Template
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Google Maps Distance Matrix API
# Used for: route optimization + travel time calculation
# Get key: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Distance Matrix API, Maps JavaScript API
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ------------------------------------------------------------
# Google Calendar API
# Used for: creating/updating/deleting showing + travel blocks
# Setup: https://console.cloud.google.com → OAuth 2.0 Client IDs
# Download credentials JSON, paste the entire JSON string here
# Scopes needed: https://www.googleapis.com/auth/calendar
# ------------------------------------------------------------
GOOGLE_CALENDAR_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"]}}

# ------------------------------------------------------------
# Gmail API
# Used for: sending client showing day page + calendar invites
# Same Google Cloud project as Calendar API
# Scopes needed: https://www.googleapis.com/auth/gmail.send
# ------------------------------------------------------------
GMAIL_CREDENTIALS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["urn:ietf:wg:oauth:2.0:oob","http://localhost"]}}

# ------------------------------------------------------------
# Lofty CRM API
# Used for: client contact lookup (primary CRM)
# Get key: Lofty Admin Panel → Settings → Integrations → API
# Contact Lofty support if API access needs to be enabled
# ------------------------------------------------------------
LOFTY_API_KEY=your_lofty_api_key_here

# ------------------------------------------------------------
# GHL (GoHighLevel / Lead Connector) API
# Used for: client contact lookup (fallback CRM) + webhook receiver
# Get key: GHL Settings → Integrations → API Keys
# Location ID: GHL Settings → Business Info → Location ID
# ------------------------------------------------------------
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# ------------------------------------------------------------
# ShowingTime API (PLACEHOLDER — not yet confirmed)
# Used for: direct showing request submission (future feature)
# Contact ShowingTime support to confirm API access availability
# ------------------------------------------------------------
SHOWINGTIME_API_KEY=placeholder_confirm_with_showingtime_support

# ------------------------------------------------------------
# Bridge API (PLACEHOLDER — not yet confirmed)
# Used for: MLS-direct listing data (future replacement for Zillow scraper)
# Contact: BridgeAPI@bridgeinteractive.com
# Confirm whether credentials are provisioned via existing IDX agreement
# ------------------------------------------------------------
BRIDGE_API_KEY=placeholder_confirm_with_bridge_interactive

# ------------------------------------------------------------
# Default Session Configuration
# Starting address for route optimization (agent's home office)
# This is pre-filled in the UI but can be overridden per session
# ------------------------------------------------------------
DEFAULT_START_ADDRESS=Plainwell, MI 49080

# ------------------------------------------------------------
# Flask Configuration
# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------
FLASK_SECRET_KEY=replace_with_strong_random_secret_key

# ------------------------------------------------------------
# Anthropic Claude API
# Used for: disclosure PDF red flag analysis (disclosure_analyzer.py)
# Get key: https://console.anthropic.com → API Keys
# ------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
