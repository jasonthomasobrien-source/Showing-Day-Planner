# Environment & credentials — NEVER commit these
.env
*.env
.env.local
.env.*.local

# Runtime session files
session_state.json
run_log.json

# Generated output (keep directory structure, ignore contents)
output/*
!output/.gitkeep
sessions/archive/*
!sessions/archive/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/
*.egg-info/
*.egg-link
MANIFEST

